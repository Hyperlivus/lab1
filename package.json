{
  "name": "notes-service",
  "version": "1.0.0",
  "description": "Simple Fastify + TypeScript notes service",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "start": "node dist/server.js",
    "migrate": "ts-node-dev scripts/migrate.ts",
    "rollback": "ts-node-dev scripts/rollback.ts",
    "create-migration": "ts-node-dev scripts/create-migration.ts"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "fastify": "^5.8.5",
    "pg": "^8.11.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/pg": "^8.11.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
