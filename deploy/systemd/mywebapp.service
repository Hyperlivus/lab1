[Unit]
Description=My Web App
After=network.target postgresql.service mywebapp.socket
Requires=postgresql.service mywebapp.socket

[Service]
Type=simple
User=mywebapp
WorkingDirectory=/opt/mywebapp
ExecStartPre=/opt/mywebapp/scripts/migrate.ts
ExecStart=/opt/mywebapp/dist/server.js
Restart=always
RestartSec=5
Environment=NODE_ENV=production
Environment=PATH=/usr/local/bin:/usr/bin:/bin
Environment=LISTEN_FDS=1

[Install]
WantedBy=multi-user.target